        "@org_golang_google_protobuf//runtime/protoimpl",
        "@org_golang_google_protobuf//types/known/timestamppb",
    ],
)

proto_library(
    name = "project_planton_shared_proto",
    srcs = [
        "iac.proto",
        "metadata.proto",
        "status.proto",
