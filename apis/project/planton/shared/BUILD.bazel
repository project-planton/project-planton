    strip_import_prefix = "/apis",
    visibility = ["//visibility:public"],
    deps = [
        "@buf_deps_apis//buf/validate:validate_proto",
        "@com_google_protobuf//:timestamp_proto",
    ],
)

buf_lint_test(
    name = "project_planton_shared_proto_lint",
    config = "//apis:buf.yaml",
    targets = [":project_planton_shared_proto"],
)
