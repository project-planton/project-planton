load("@rules_buf//buf:defs.bzl", "buf_lint_test")
load("@rules_go//go:def.bzl", "go_library", "go_test")
load("@rules_proto//proto:defs.bzl", "proto_library")

go_library(
    name = "pulumi",
    srcs = ["pulumi.pb.go"],
    importpath = "github.com/project-planton/project-planton/apis/project/planton/shared/iac/pulumi",
    visibility = ["//visibility:public"],
    deps = [
        "//apis/project/planton/shared/iac/iacgitrepo",
        "@build_buf_gen_go_bufbuild_protovalidate_protocolbuffers_go//buf/validate",
        "@org_golang_google_protobuf//reflect/protoreflect",
        "@org_golang_google_protobuf//runtime/protoimpl",
    ],
)

go_test(
    name = "pulumi_test",
    srcs = ["pulumi_test.go"],
    embed = [":pulumi"],
    deps = [
        "@com_github_bufbuild_protovalidate_go//:protovalidate-go",
        "@com_github_onsi_ginkgo_v2//:ginkgo",
        "@com_github_onsi_gomega//:gomega",
    ],
)

proto_library(
    name = "project_planton_shared_iac_pulumi_proto",
    srcs = ["pulumi.proto"],
    strip_import_prefix = "/apis",
    visibility = ["//visibility:public"],
    deps = [
        "//apis/project/planton/shared/iac/iacgitrepo:project_planton_shared_iac_iacgitrepo_proto",
        "@buf_deps_apis//buf/validate:validate_proto",
    ],
)

buf_lint_test(
    name = "project_planton_shared_iac_pulumi_proto_lint",
    config = "//apis:buf.yaml",
    targets = [":project_planton_shared_iac_pulumi_proto"],
)
